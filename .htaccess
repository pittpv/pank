# Apache .htaccess для запуска Sber PWA на обычном хостинге
# Замените стандартный .htaccess этим файлом

RewriteEngine On
RewriteBase /

# Установить правильные MIME-типы
AddType application/manifest+json webmanifest
AddType font/woff2 woff2
AddType font/woff woff

# Кэширование для шрифтов
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

# Отключение кэширования для HTML и Service Worker
<FilesMatch "\.(htm|html)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache"
  </IfModule>
</FilesMatch>

<FilesMatch "sw\.js$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache"
    Header set Service-Worker-Allowed "/"
  </IfModule>
</FilesMatch>

<FilesMatch "\.(webmanifest)$">
  <IfModule mod_headers.c>
    Header set Content-Type "application/manifest+json"
  </IfModule>
</FilesMatch>

<FilesMatch "\.(woff2|woff)$">
  <IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
  </IfModule>
</FilesMatch>

# Маршрутизация SPA - основные пути
RewriteRule ^$ index.html [L]
RewriteRule ^app/?$ Main.htm [L]
RewriteRule ^app/main/?$ Main.htm [L]
RewriteRule ^app/savings/?$ Savings.htm [L]
RewriteRule ^app/adm/?$ adm.htm [L]

# Легаси пути (Sber * → *)
RewriteRule ^Sber%20Main_files/(.*)$ Main_files/$1 [L]
RewriteRule ^Sber%20Savings_files/(.*)$ Savings_files/$1 [L]
RewriteRule ^Sber Main_files/(.*)$ Main_files/$1 [L]
RewriteRule ^Sber Savings_files/(.*)$ Savings_files/$1 [L]

# Перенаправление всех остальных запросов под /app/ на файлы если они существуют
# Иначе на Main.htm (для SPA роутинга)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} ^/app/
RewriteRule ^app/(.*)$ Main.htm [L]

# Для корневого пути и других несуществующих файлов - индекс
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.html [L]
