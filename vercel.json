{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/app", "destination": "/Main.htm" },
    { "source": "/app/", "destination": "/Main.htm" },
    { "source": "/app/main", "destination": "/Main.htm" },
    { "source": "/app/main/", "destination": "/Main.htm" },
    { "source": "/app/savings", "destination": "/Savings.htm" },
    { "source": "/app/savings/", "destination": "/Savings.htm" },
    { "source": "/app/adm", "destination": "/adm.htm" },
    { "source": "/app/adm/", "destination": "/adm.htm" },
    { "source": "/app/:path*", "destination": "/Main.htm" },
    { "source": "/Sber%20Main_files/:path*", "destination": "/Main_files/:path*" },
    { "source": "/Sber%20Savings_files/:path*", "destination": "/Savings_files/:path*" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/:path*.(htm|html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/:path*.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    },
    {
      "source": "/:path*.(woff2|woff)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=31536000" }
      ]
    }
  ]
}
